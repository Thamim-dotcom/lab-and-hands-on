# Lab & Hands-On — .gitignore
# ===================================
# SECURITY: Never commit these files
# ===================================

# Real credentials, keys, tokens
*.pem
*.key
*.cert
*.crt
id_rsa
id_rsa.pub
id_ed25519
*.p12
*.pfx
*.jks

# Environment files with secrets
.env
.env.local
.env.*.local
secrets.txt
credentials.txt
passwords.txt

# Database files (may contain sensitive data)
*.db
*.sqlite
*.sqlite3

# Live capture files
*.pcap
*.pcapng
*.cap

# Tool output with real IPs/data
loot/
exfil/
private/

# ===================================
# OS generated
# ===================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ===================================
# Editor artifacts
# ===================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ===================================
# Python
# ===================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
env/
*.egg

# ===================================
# Node.js
# ===================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ===================================
# Rust
# ===================================
target/
Cargo.lock

# ===================================
# Logs
# ===================================
*.log
logs/

# ===================================
# Archives (may contain real payloads)
# ===================================
# Exception: intentionally shared archives should be committed explicitly
# *.zip
# *.tar.gz
# *.7z
